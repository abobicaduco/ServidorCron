# Copy to .env and adjust (optional — many defaults work for local dev)
# Never commit .env with real secrets.

# Flask session secret (required in production)
# ABOBI_SECRET_KEY=replace-with-long-random-string

# E-mail domain appended to username for token delivery (e.g. @yourcompany.com)
# ABOBI_EMAIL_DOMAIN=@example.com

# Comma-separated login names (no domain). First entry is typical admin.
# ABOBI_ADMIN_USERS=admin
# ABOBI_EXTRA_VIEWERS=viewer1,viewer2

# Set to 1 for dev without Outlook
# ABOBI_MOCK_EMAIL=1

# HTTP
# ABOBI_HOST=0.0.0.0
# ABOBI_PORT=5002

# Paths (optional — defaults: ./automations and ./optional_cobranca_cron.xlsx)
# ABOBI_AUTOMATIONS_DIR=C:\path\to\automations
# ABOBI_COBRANCA_CRON_XLSX=C:\path\to\optional_cobranca.xlsx

# BigQuery full table ids (project.dataset.table)
# BQ_REGISTRO_TABLE=your-gcp-project.your_dataset.registro_automacoes
# BQ_ACCESS_TABLE=your-gcp-project.your_dataset.access_registry
